# Copy this file to .env when running locally, or set these as
# Environment Variables in your Railway/Render dashboard when deploying.

# Your HubSpot Private App / Service Key access token.
# Get this from HubSpot: Settings > Integrations > Private Apps (or Service Keys)
HUBSPOT_TOKEN=paste_your_hubspot_token_here

# The password you'll type to access your dashboard. Choose your own.
DASHBOARD_PASSWORD=choose_a_password_here

# Once your frontend is deployed on Vercel, paste its URL here
# (e.g. https://dealmind-dashboard.vercel.app)
# This restricts who can call this backend.
ALLOWED_ORIGIN=*
